# Configuração do Banco de Dados
DATABASE_URL="postgresql://username:password@localhost:5432/estoque_db"

# NextAuth.js
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Mercado Livre API
ML_CLIENT_ID="seu_app_id_aqui"
ML_CLIENT_SECRET="sua_secret_key_aqui"
ML_REDIRECT_URI="http://localhost:3000/configuracoes"

# Outras configurações necessárias
# Em produção, altere ML_REDIRECT_URI para sua URL de produção
# Ex: ML_REDIRECT_URI="https://seu-dominio.com/configuracoes" 
# Bling API v3 (OAuth)
BLING_CLIENT_ID="seu_client_id_bling"
BLING_CLIENT_SECRET="seu_client_secret_bling"
BLING_REDIRECT_URI="http://localhost:3000/api/bling/auth/callback"
# Em produção: BLING_REDIRECT_URI="https://seu-dominio.com/api/bling/auth/callback"

# Cron (Vercel)
CRON_SECRET="chave-secreta-para-crons"
